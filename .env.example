# Lycan-Data Environment Configuration
# Copy to .env and update values before running.
# Docker Compose defaults use Docker service names.
# For local dev without Docker, change service names to localhost.

# --- Database ---
POSTGRES_DB=lycan
POSTGRES_USER=lycan
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://lycan:changeme@postgres:5432/lycan
DATABASE_URL_SYNC=postgresql://lycan:changeme@postgres:5432/lycan

# --- Cache (Garnet / Dragonfly / Redis-compatible) ---
CACHE_URL=redis://garnet:6379/0
# Legacy alias (still accepted):
# DRAGONFLY_URL=redis://garnet:6379/0

# --- Typesense (replaced MeiliSearch — BSL 1.1 license banned) ---
TYPESENSE_URL=http://typesense:8108
TYPESENSE_API_KEY=changeme

# --- FlareSolverr (Cloudflare bypass proxy) ---
FLARESOLVERR_URL=http://flaresolverr:8191/v1

# --- SpiderFoot (leave blank if not running) ---
SPIDERFOOT_URL=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Tor Configuration ---
TOR_CONTROL_PASSWORD=changeme
TOR_ENABLED=true
TOR1_SOCKS=socks5://tor-1:9050
TOR1_CONTROL_HOST=tor-1
TOR1_CONTROL_PORT=9051
TOR2_SOCKS=socks5://tor-2:9050
TOR2_CONTROL_HOST=tor-2
TOR2_CONTROL_PORT=9053
TOR3_SOCKS=socks5://tor-3:9050
TOR3_CONTROL_HOST=tor-3
TOR3_CONTROL_PORT=9055

# --- Proxy Configuration ---
PROXY_OVERRIDE=
RESIDENTIAL_PROXIES=
DATACENTER_PROXIES=
DEFAULT_PROXY_TIER=tor
I2P_SOCKS=
I2P_ENABLED=false

# --- Evasion / Anti-Detection ---
HUMAN_DELAY_MIN=1.5
HUMAN_DELAY_MAX=6.0
JITTER_ENABLED=true
ROTATE_USER_AGENT=true
ROTATE_TLS_FINGERPRINT=true

# --- Module Kill Switches ---
ENABLE_INSTAGRAM=true
ENABLE_LINKEDIN=true
ENABLE_TWITTER=true
ENABLE_FACEBOOK=true
ENABLE_TIKTOK=true
ENABLE_TELEGRAM=true
ENABLE_DARKWEB=true
ENABLE_BURNER_CHECK=true
ENABLE_CREDIT_RISK=true
ENABLE_WEALTH=true
ENABLE_CRIMINAL_SIGNALS=true
ENABLE_CRYPTO_TRACE=true

# --- Feature Flags ---
ENABLE_UBO_DISCOVERY=true
ENABLE_COMPANY_INTEL_CRAWL=true

# --- Freshness ---
FRESHNESS_THRESHOLD=0.40
RESCRAPE_ON_STALENESS=true

# --- Optional API Overrides (core search works without these) ---
ATTOM_API_KEY=
OPENSANCTIONS_API_KEY=
OPENCORPORATES_API_KEY=
MARINETRAFFIC_API_KEY=

# --- Budget ---
DAILY_API_BUDGET_USD=0

# --- App ---
SECRET_KEY=changeme-32-chars-minimum-please
API_KEYS=changeme
API_AUTH_ENABLED=false
DEBUG=false
LOG_LEVEL=INFO
PYTHONPATH=.
ENVIRONMENT=dev
