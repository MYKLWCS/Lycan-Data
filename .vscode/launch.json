{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Lycan: Debug",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "api.main:app",
                "--host", "0.0.0.0",
                "--port", "8000",
                "--reload"
            ],
            "python": "${workspaceFolder}/.venv/bin/python",
            "pythonArgs": ["-Xfrozen_modules=off"],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "DEBUG": "true"
            },
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Lycan: Debug File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "pythonArgs": ["-Xfrozen_modules=off"],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Lycan: Debug Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-v",
                "--tb=short",
                "--no-header",
                "-x"
            ],
            "python": "${workspaceFolder}/.venv/bin/python",
            "pythonArgs": ["-Xfrozen_modules=off"],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Lycan: Debug All Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/",
                "--ignore=tests/test_integration.py",
                "-v",
                "--tb=short",
                "-x"
            ],
            "python": "${workspaceFolder}/.venv/bin/python",
            "pythonArgs": ["-Xfrozen_modules=off"],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Lycan: Debug All Tests MAX",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/",
                "--ignore=tests/test_integration.py",
                "-v",
                "--tb=long",
                "--showlocals",
                "--full-trace",
                "-rA",
                "--strict-markers",
                "--durations=0",
                "-W", "default",
                "--cov=.",
                "--cov-report=term-missing",
                "--cov-fail-under=100"
            ],
            "python": "${workspaceFolder}/.venv/bin/python",
            "pythonArgs": ["-Xfrozen_modules=off"],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "console": "integratedTerminal"
        }
    ]
}