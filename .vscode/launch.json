{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "API Service",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "api.main:app",
                "--host", "0.0.0.0",
                "--port", "8000"
            ],
            "jinja": true,
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "presentation": {
                "hidden": true
            }
        },
        {
            "name": "Worker Service",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/worker.py",
            "args": [
                "--workers", "4"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "presentation": {
                "hidden": true
            }
        }
    ],
    "compounds": [
        {
            "name": "Lycan: Debug Everything (API & Worker)",
            "configurations": ["API Service", "Worker Service"]
        }
    ]
}